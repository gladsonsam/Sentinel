{
  "productName": "sentinel-agent",
  "version": "0.1.0",
  "identifier": "com.sentinel.agent",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "./ui-src/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Agent Settings",
        "url": "index.html",
        "width": 520,
        "height": 680,
        "minWidth": 520,
        "minHeight": 680,
        "resizable": false,
        "visible": false,
        "center": true,
        "decorations": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
