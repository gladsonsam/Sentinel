# ── Sentinel minimal stack (copy to `.env` and edit) ─────────────────────────
# Full variable list: https://github.com/gladsonsam/Sentinel/wiki/Configuration

# Database (required by Docker Compose)
POSTGRES_PASSWORD=change-me-strong-password

# Dashboard bootstrap admin (first run only; then users are stored in Postgres)
ADMIN_PASSWORD=change-me-admin-password

# Agents must use the same secret (see wiki → Usage → Windows agent)
AGENT_SECRET=change-me-agent-secret

# Dashboard on http://localhost:9000 (set empty only if you use a reverse proxy file)
PUBLISH_PORT=9000

# Plain HTTP without TLS in front — set true only behind HTTPS reverse proxy
ENFORCE_HTTPS=false

# Optional overrides (defaults shown)
# POSTGRES_DB=monitor
# POSTGRES_USER=monitor
